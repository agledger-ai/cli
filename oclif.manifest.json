    "verify": {
      "aliases": [],
      "args": {
        "file": {
          "description": "Path to the audit export JSON file (or \"-\" for stdin).",
          "name": "file",
          "required": true
        }
      },
      "description": "Verify a record audit export offline (hash chain + Ed25519 signatures, RFC 8785).",
      "examples": [
        "<%= config.bin %> verify audit-export.json",
        "<%= config.bin %> verify audit-export.json --keys vault-keys.json",
        "<%= config.bin %> verify audit-export.json --json",
        "cat audit-export.json | <%= config.bin %> verify -"
      ],
      "flags": {
        "json": {
          "description": "Force JSON output (default when stdout is piped)",
          "name": "json",
          "allowNo": false,
          "type": "boolean"
