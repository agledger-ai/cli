{
  "commands": {
    "api": {
      "aliases": [],
      "args": {
        "method": {
          "description": "HTTP method (GET, POST, PUT, PATCH, DELETE)",
          "name": "method",
          "required": true
        },
        "path": {
          "description": "Full API path including version prefix (e.g. /v1/records, /health, /federation/v1/register)",
          "name": "path",
          "required": true
        }
      },
      "description": "Call any AGLedger API endpoint. Pass-through with zero flag translation — use the exact path and body shape documented in the API (see `agledger discover` or GET /openapi.json).",
      "examples": [
        "agledger api GET /health",
        "agledger api GET /v1/records -F status=ACTIVE -F limit=50",
        "agledger api POST /v1/records --data '{\"type\":\"ACH-PROC-v1\",\"criteria\":{\"item_spec\":\"...\"}}'",
        "agledger api POST /v1/records -F type=ACH-PROC-v1 -F criteria.item_spec=widgets -F criteria.quantity.target=500",
        "agledger api POST /v1/records --input payload.json",
        "cat payload.json | agledger api POST /v1/records --input -",
        "agledger api GET /v1/records --paginate  # streams all pages as NDJSON"
      ],
      "flags": {
        "json": {
          "description": "Force JSON output (default when stdout is piped)",
          "name": "json",
          "allowNo": false,
          "type": "boolean"
        },
        "quiet": {
          "description": "Suppress output (exit code only)",
          "name": "quiet",
          "allowNo": false,
          "type": "boolean"
        },
        "api-key": {
          "description": "AGLedger API key",
          "env": "AGLEDGER_API_KEY",
          "name": "api-key",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "api-url": {
          "description": "AGLedger API base URL",
          "env": "AGLEDGER_API_URL",
          "name": "api-url",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "data": {
          "description": "Request body as a JSON string. For GET/DELETE, used as query parameters.",
          "name": "data",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "input": {
          "description": "Read body JSON from file (or \"-\" for stdin). Shape matches --data.",
          "name": "input",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "field": {
          "char": "F",
          "description": "Set a field as key=value. Values are typed: true/false/null, numbers, or JSON for {...}/[...]. Supports nested (a.b.c=v) and array append (arr[]=v). Repeatable.",
          "name": "field",
          "hasDynamicHelp": false,
          "multiple": true,
          "type": "option"
        },
        "query": {
          "description": "Extra query parameters as JSON. Merges over -F fields and --data for GET/DELETE routing.",
          "name": "query",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "paginate": {
          "description": "Follow cursor pagination, stream all results as NDJSON. Requires GET on a paginated route.",
          "name": "paginate",
          "allowNo": false,
          "type": "boolean"
        },
        "dry-run": {
          "description": "Show the request that would be sent without calling the API.",
          "name": "dry-run",
          "allowNo": false,
          "type": "boolean"
        }
      },
      "hasDynamicHelp": false,
      "hiddenAliases": [],
      "id": "api",
      "pluginAlias": "@agledger/cli",
      "pluginName": "@agledger/cli",
      "pluginType": "core",
      "strict": true,
      "enableJsonFlag": false,
      "isESM": true,
      "relativePath": [
        "dist",
        "commands",
        "api.js"
      ]
    },
